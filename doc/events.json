{
  "event": {
    "eventId": "<uuid>",
    "source": "order|inventory|payment|notification",
    "type": "<event-type>",
    "timestamp": "<iso-8601 utc>",
    "payload": {
      "<camp-1>": "<value>",
      "<camp-2>": "<value>",
      "<camp-n>": "<value>"
    }
  },
  "flow": [
    { "from": "order", "to": "inventory", "type": "order.created" },
    { "from": "inventory", "to": "order", "type": "inventory.reserved" },
    { "from": "inventory", "to": "order", "type": "inventory.failed" },
    { "from": "order", "to": "payment", "type": "payment.requested" },
    { "from": "payment", "to": "order", "type": "payment.processed" },
    { "from": "payment", "to": "order", "type": "payment.failed" },
    { "from": "order", "to": "notification", "type": "order.completed" },
    { "from": "order", "to": "notification", "type": "order.cancelled" }
  ]
}
